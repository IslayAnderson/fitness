{% extends 'layout.twig' %}
{% block content %}
    <section class="data">
        <h1 class="data__title">Progress Data</h1>
        <p class="data__intro">Trends over time from your measurements, exercise logs, and diary entries.</p>

        <div class="data__overview">
            <div class="data__overview-quarter">
                {{ weeks }}
            </div>
            <div class="data__overview-quarter">
                <svg width="24" height="24" xmlns="http://www.w3.org/2000/svg" fill-rule="evenodd" clip-rule="evenodd"><path fill="#000" d="M12 0c6.623 0 12 5.377 12 12s-5.377 12-12 12-12-5.377-12-12 5.377-12 12-12zm0 1c6.071 0 11 4.929 11 11s-4.929 11-11 11-11-4.929-11-11 4.929-11 11-11zm0 11h6v1h-7v-9h1v8z"/></svg>
                {{ hours }} Total Hours
            </div>
            <div class="data__overview-quarter">
                {{ workouts }} Workouts
            </div>
            <div class="data__overview-quarter">
                {{ total_weight }}kg
            </div>
        </div>

        <div class="data__charts">
            <h2 class="chart__title">Measurements Over Time</h2>
            <article class="chart">
                <div id="measurementsChart" class="chart__stage" role="img" aria-label="Measurements over time"></div>
            </article>

            <h2 class="chart__title">Weight (Volume kg)</h2>
            <article class="chart">
                <div id="exerciseChart" class="chart__stage" role="img" aria-label="Weights over recent logs"></div>
            </article>

            <h2 class="chart__title">Diary Frequency</h2>
            <article class="chart">
                <div id="diaryChart" class="chart__stage" role="img" aria-label="Diary entries per day"></div>
            </article>
        </div>
    </section>
{% endblock %}
